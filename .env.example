# --- App ---
APP_NAME=AutoCRM API
DEBUG=false

# --- Auth / JWT ---
# Сгенерировать: openssl rand -hex 32
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- PostgreSQL ---
POSTGRES_USER=autocrm
POSTGRES_PASSWORD=autocrm
POSTGRES_DB=autocrm
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Полная строка подключения (перекрывает POSTGRES_*).
# В docker-compose задаётся автоматически, раскомментируй для локального запуска без Docker:
# DATABASE_URL=postgresql+psycopg://autocrm:autocrm@localhost:5432/autocrm

# --- Seed (демо-пользователи для python -m app.seed) ---
SEED_ADMIN_EMAIL=admin@autocrm.local
SEED_ADMIN_PASSWORD=admin123
SEED_MANAGER_EMAIL=manager@autocrm.local
SEED_MANAGER_PASSWORD=manager123
